   "execution_count": null,
   "metadata": {},
   "outputs": [],{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Network Packet Transmission Simulator\n",
    "\n",
    "This notebook simulates network packet transmission in a network. Each packet can either be delivered successfully or lost (simulated randomly). The notebook visualizes delivered vs lost packets and calculates success rate. Optional animation demonstrates the packet flow."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import random\n",
    "import matplotlib.pyplot as plt\n",
    "import time"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Total number of packets to simulate\n",
    "num_packets = 20\n",
    "packets = list(range(1, num_packets + 1))\n",
    "\n",
    "# Lists to store delivered and lost packets\n",
    "delivered = []\n",
    "lost = []\n",
    "\n",
    "# Packet loss probability\n",
    "packet_loss_probability = 0.2  # 20% chance packet is lost"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Simulate transmission of packets\n",
    "for p in packets:\n",
    "    if random.random() > packet_loss_probability:\n",
    "        delivered.append(p)\n",
    "    else:\n",
    "        lost.append(p)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualize packet transmission\n",
    "plt.figure(figsize=(10,2))\n",
    "plt.scatter(delivered, [1]*len(delivered), color='green', label='Delivered', s=100)\n",
    "plt.scatter(lost, [1]*len(lost), color='red', label='Lost', s=100)\n",
    "plt.yticks([])\n",
    "plt.xlabel('Packet Number')\n",
    "plt.title('Packet Transmission Simulation')\n",
    "plt.legend()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Print stats\n",
    "success_rate = len(delivered)/num_packets*100\n",
    "print(f\"Packets Delivered: {len(delivered)}\")\n",
    "print(f\"Packets Lost: {len(lost)}\")\n",
    "print(f\"Success Rate: {success_rate:.2f}%\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Optional Animation\n",
    "\n",
    "This cell animates packet transmission to show packet flow in real time. Green dots = delivered packets, Red dots = lost packets. Useful for visual understanding of network reliability."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "plt.figure(figsize=(10,2))\n",
    "plt.ion()  # Interactive mode on\n",
    "\n",
    "delivered_anim = []\n",
    "lost_anim = []\n",
    "\n",
    "for p in packets:\n",
    "    if random.random() > packet_loss_probability:\n",
    "        color = 'green'\n",
    "        delivered_anim.append(p)\n",
    "    else:\n",
    "        color = 'red'\n",
    "        lost_anim.append(p)\n",
    "    plt.scatter(p, 1, color=color, s=100)\n",
    "    plt.yticks([])\n",
    "    plt.xlabel('Packet Number')\n",
    "    plt.title('Animated Packet Transmission')\n",
    "    plt.pause(0.5)\n",
    "\n",
    "plt.ioff()\n",
    "plt.show()"
   ]
  }
 ],
